# =============================================================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================================================

# Puerto del servidor
PORT=3000

# Entorno de ejecución: development, production, test
NODE_ENV=development

# =============================================================================
# CONFIGURACIÓN DE JWT
# =============================================================================

# Clave secreta para firmar tokens JWT (MÍNIMO 64 caracteres)
# IMPORTANTE: En producción usar una clave segura y almacenarla en un secrets manager
JWT_SECRET=your-64-character-minimum-secret-key-here-xxxxxxxxxxxxxxxxxxxxxx

# Clave secreta para firmar refresh tokens (MÍNIMO 64 caracteres)
JWT_REFRESH_SECRET=your-64-character-minimum-refresh-secret-key-xxxxxxxxxxxxxxxx

# =============================================================================
# CONFIGURACIÓN DE CORREO ELECTRÓNICO
# =============================================================================

# Servidor SMTP
EMAIL_HOST=smtp.gmail.com

# Usuario de correo electrónico
EMAIL_USER=tu-correo@gmail.com

# Contraseña de aplicación (no tu contraseña normal)
EMAIL_PASS=tu-contraseña-de-aplicación

# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# =============================================================================

# Dialecto de la base de datos
DATABASE_DIALECT=postgres

# Host de la base de datos (localhost para desarrollo local, db para Docker)
DATABASE_HOST=localhost

# Puerto de la base de datos
DATABASE_PORT=5432

# Credenciales de PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu-contraseña-segura
POSTGRES_DB=api_nest

# =============================================================================
# CONFIGURACIÓN DE SEGURIDAD
# =============================================================================

# Número de rondas para bcrypt (1-100)
SALT_ROUNDS=10

# Configuración de CORS (separados por coma)
CORS=http://localhost:5173,http://localhost:4173

# =============================================================================
# CONFIGURACIÓN DE RATE LIMITING
# =============================================================================

# Tiempo de vida del rate limit en milisegundos (1000 - 600000)
RATE_LIMIT_TTL=60000

# Límite de peticiones (1 - 1000)
RATE_LIMIT_LIMIT=100

# =============================================================================
# CONFIGURACIÓN DE ENCRIPTACIÓN
# =============================================================================

# Clave secreta para encriptar datos sensibles con AES-256-GCM (MÍNIMO 32 caracteres)
ENCRYPTION_KEY=your-32-character-minimum-encryption-key

# =============================================================================
# CONFIGURACIÓN DE REDIS
# =============================================================================


# Redis PORT
REDIS_PORT=6382

# URL de conexión a Redis
REDIS_URL=redis://redis:${REDIS_PORT}

# =============================================================================
# CONFIGURACIÓN DE FRONTEND
# =============================================================================

# URL del frontend para redirecciones
FRONT_END_URL=http://localhost:5173