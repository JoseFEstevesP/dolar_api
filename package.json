{
	"name": "api-nest",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "rm -f src/metadata.ts && nest build && rm -f dist/metadata.js",
		"start": "nest start",
		"dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"lint": "oxlint src/ --quiet",
		"lint:fix": "oxlint src/ --fix --quiet",
		"lint:check": "oxlint src/",
		"lintStaged": "lint-staged",
		"migrate:undo:all": "sequelize-cli db:migrate:undo:all",
		"migrate:undo": "sequelize-cli db:migrate:undo",
		"migrate": "sequelize-cli db:migrate",
		"migrate:create": "node scripts/generateESMMigration.js",
		"module:generate": "node scripts/moduleGenerator.js",
		"module:generate:basic": "node scripts/moduleGenerator.js --basic",
		"module:generate:standard": "node scripts/moduleGenerator.js --standard",
		"module:generate:complete": "node scripts/moduleGenerator.js --complete",
		"prepare": "husky",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"docker:logs": "docker compose logs -f",
		"docker:migrate": "docker compose run --rm migrate",
		"docker:migrate:undo": "docker compose run --rm migrate-undo",
		"docker:migrate:create": "docker compose run --rm migrate pnpm run migrate:create",
		"seed": "tsx src/scripts/seed.ts",
		"setup:test-db": "node scripts/setup-test-db.js",
		"pretest": "pnpm run setup:test-db",
		"test": "vitest run --config vitest.config.ts",
		"test:all": "node scripts/run-tests.js",
		"test:watch": "vitest",
		"test:cov": "vitest run --config vitest.config.ts --coverage"
	},
	"dependencies": {
		"@formkit/tempo": "1.0.0",
		"@keyv/redis": "5.1.6",
		"@nestjs/cache-manager": "3.1.0",
		"@nestjs/common": "11.1.16",
		"@nestjs/config": "4.0.3",
		"@nestjs/core": "11.1.16",
		"@nestjs/mapped-types": "2.1.0",
		"@nestjs/platform-express": "11.1.16",
		"@nestjs/schedule": "6.1.1",
		"@nestjs/serve-static": "5.0.4",
		"@nestjs/terminus": "11.1.1",
		"@nestjs/throttler": "6.5.0",
		"@types/passport-google-oauth20": "2.0.17",
		"bcrypt": "6.0.0",
		"cache-manager": "7.2.8",
		"class-transformer": "0.5.1",
		"class-validator": "0.15.1",
		"compression": "1.8.1",
		"cookie-parser": "1.4.7",
		"dotenv": "17.3.1",
		"express": "5.2.1",
		"helmet": "8.1.0",
		"jose": "^6.2.3",
		"keyv": "5.6.0",
		"multer": "2.1.1",
		"nodemailer": "8.0.2",
		"passport-google-oauth20": "2.0.0",
		"pg": "8.20.0",
		"pg-hstore": "2.3.4",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2",
		"sequelize": "6.37.8",
		"sequelize-typescript": "2.1.6",
		"winston": "3.19.0",
		"winston-daily-rotate-file": "5.0.0"
	},
	"devDependencies": {
		"@commitlint/cli": "20.4.3",
		"@commitlint/config-conventional": "20.4.3",
		"@nestjs/cli": "11.0.16",
		"@nestjs/schematics": "11.0.9",
		"@nestjs/sequelize": "11.0.1",
		"@nestjs/swagger": "11.4.2",
		"@nestjs/testing": "11.1.16",
		"@swc/cli": "0.8.0",
		"@swc/core": "1.15.18",
		"@testcontainers/postgresql": "^11.12.0",
		"@testcontainers/redis": "^11.12.0",
		"@types/bcrypt": "6.0.0",
		"@types/compression": "1.8.1",
		"@types/cookie-parser": "1.4.10",
		"@types/express": "5.0.6",
		"@types/multer": "2.1.0",
		"@types/node": "25.4.0",
		"@types/nodemailer": "7.0.11",
		"@types/pg": "8.11.11",
		"@types/supertest": "7.2.0",
		"husky": "9.1.7",
		"lint-staged": "16.3.3",
		"oxlint": "1.52.0",
		"prettier": "3.8.1",
		"sequelize-cli": "6.6.5",
		"testcontainers": "11.12.0",
		"tsconfig-paths": "4.2.0",
		"tsx": "^4.21.0",
		"typescript": "5.9.3",
		"vitest": "^4.0.18"
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	},
	"lint-staged": {
		"**/*.{ts,js}": [
			"pnpm format",
			"pnpm lint:check"
		]
	},
	"pnpm": {
		"overrides": {
			"@nestjs/core": "11.1.16"
		},
		"onlyBuiltDependencies": [
			"@nestjs/core",
			"@scarf/scarf",
			"@swc/core",
			"bcrypt",
			"cpu-features",
			"esbuild",
			"sharp",
			"ssh2",
			"unrs-resolver"
		]
	}
}
