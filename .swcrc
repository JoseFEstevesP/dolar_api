{
	"$schema": "https://json.schemastore.org/swcrc",
	"jsc": {
		"target": "es2021",
		"parser": {
			"syntax": "typescript",
			"decorators": true,
			"dynamicImport": true
		},
		"transform": {
			"decoratorMetadata": true,
			"legacyDecorator": true
		},
		"keepClassNames": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"sourceMaps": true,
	"module": {
		"type": "commonjs"
	}
}
